<Page
    x:Class="BeamDrop.Windows.App.Views.TransferProgressPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <StackPanel Spacing="20" Padding="36">
        <TextBlock Text="Transfer Progress" Style="{StaticResource PageTitleTextBlockStyle}" />
        <Border Style="{StaticResource DeviceCardStyle}">
            <StackPanel Spacing="12">
                <TextBlock Text="Ready" Style="{StaticResource SectionTitleTextBlockStyle}" />
                <ProgressBar Value="0" />
                <TextBlock Text="No transfer is active. Active transfers show route, speed, current item, verification, pause, cancel, and retry actions." Style="{StaticResource MutedTextBlockStyle}" />
                <StackPanel Orientation="Horizontal" Spacing="10">
                    <Button Content="Pause" IsEnabled="False" />
                    <Button Content="Cancel Transfer" IsEnabled="False" />
                    <Button Content="Retry" IsEnabled="False" />
                </StackPanel>
            </StackPanel>
        </Border>
    </StackPanel>
</Page>
