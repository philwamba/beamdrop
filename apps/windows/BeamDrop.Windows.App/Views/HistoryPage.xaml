<Page
    x:Class="BeamDrop.Windows.App.Views.HistoryPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <StackPanel Spacing="20" Padding="36">
        <TextBlock Text="History" Style="{StaticResource PageTitleTextBlockStyle}" />
        <Border Style="{StaticResource DeviceCardStyle}">
            <StackPanel Spacing="8">
                <TextBlock Text="No transfers yet" Style="{StaticResource SectionTitleTextBlockStyle}" />
                <TextBlock Text="Completed, failed, rejected, and resumable transfers will appear here without retaining sensitive text previews by default." Style="{StaticResource MutedTextBlockStyle}" />
            </StackPanel>
        </Border>
    </StackPanel>
</Page>
