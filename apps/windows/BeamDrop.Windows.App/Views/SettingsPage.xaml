<Page
    x:Class="BeamDrop.Windows.App.Views.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer>
        <StackPanel Spacing="20" Padding="36">
            <TextBlock Text="Settings" Style="{StaticResource PageTitleTextBlockStyle}" />
            <Border Style="{StaticResource DeviceCardStyle}">
                <StackPanel Spacing="14">
                    <TextBox Header="Device name" Text="Windows PC" />
                    <ComboBox Header="Theme" SelectedIndex="0">
                        <ComboBoxItem Content="Use Windows setting" />
                        <ComboBoxItem Content="Light" />
                        <ComboBoxItem Content="Dark" />
                    </ComboBox>
                    <ToggleSwitch Header="Show transfer notifications" IsOn="True" />
                    <ToggleSwitch Header="Auto-accept from trusted devices" IsOn="False" />
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>
