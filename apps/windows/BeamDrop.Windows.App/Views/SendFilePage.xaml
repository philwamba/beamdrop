<Page
    x:Class="BeamDrop.Windows.App.Views.SendFilePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <StackPanel Spacing="20" Padding="36">
        <TextBlock Text="Send File" Style="{StaticResource PageTitleTextBlockStyle}" />
        <Border Style="{StaticResource DeviceCardStyle}" MinHeight="240">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="12">
                <TextBlock Text="Drop Files Here" FontSize="24" FontWeight="SemiBold" HorizontalAlignment="Center" />
                <TextBlock Text="Files remain local. BeamDrop streams large files in 4 MB chunks and verifies SHA-256 before marking a receive complete." Style="{StaticResource MutedTextBlockStyle}" HorizontalAlignment="Center" />
                <Button Content="Choose Files" HorizontalAlignment="Center" />
            </StackPanel>
        </Border>
    </StackPanel>
</Page>
