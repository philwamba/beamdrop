<Page
    x:Class="BeamDrop.Windows.App.Views.OnboardingPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer>
        <StackPanel Spacing="20" Padding="36">
            <TextBlock Text="Onboarding" Style="{StaticResource PageTitleTextBlockStyle}" />
            <Border Style="{StaticResource DeviceCardStyle}">
                <StackPanel Spacing="10">
                    <TextBlock Text="Private Local Transfer" Style="{StaticResource SectionTitleTextBlockStyle}" />
                    <TextBlock Text="Send text and files between trusted devices without requiring login or cloud upload for local MVP transfers." Style="{StaticResource MutedTextBlockStyle}" />
                </StackPanel>
            </Border>
            <Border Style="{StaticResource DeviceCardStyle}">
                <StackPanel Spacing="10">
                    <TextBlock Text="Pair With QR" Style="{StaticResource SectionTitleTextBlockStyle}" />
                    <TextBlock Text="Trust is explicit. Unknown devices cannot send content until approved, and revoked devices are blocked." Style="{StaticResource MutedTextBlockStyle}" />
                </StackPanel>
            </Border>
            <Border Style="{StaticResource DeviceCardStyle}">
                <StackPanel Spacing="10">
                    <TextBlock Text="Clipboard Is Manual" Style="{StaticResource SectionTitleTextBlockStyle}" />
                    <TextBlock Text="Use Send Clipboard from the tray or app. BeamDrop must not silently send sensitive-looking content." Style="{StaticResource MutedTextBlockStyle}" />
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>
