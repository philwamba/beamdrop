<Page
    x:Class="BeamDrop.Windows.App.Views.ScanQrPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer>
        <StackPanel Spacing="20" Padding="36">
            <TextBlock Text="Scan QR" Style="{StaticResource PageTitleTextBlockStyle}" />
            <InfoBar Title="Camera Import Is Optional" Message="Use camera scanning when available, or paste the pairing payload from another BeamDrop device." Severity="Informational" IsOpen="True" />
            <Border Style="{StaticResource DeviceCardStyle}">
                <StackPanel Spacing="12">
                    <TextBlock Text="Import Pairing Code" Style="{StaticResource SectionTitleTextBlockStyle}" />
                    <TextBox Header="BeamDrop QR Payload" PlaceholderText="Paste pairing JSON or QR payload text" AcceptsReturn="True" TextWrapping="Wrap" MinHeight="160" />
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <Button Content="Validate Pairing Code" />
                        <Button Content="Open Camera Scanner" IsEnabled="False" />
                    </StackPanel>
                    <TextBlock Text="Approving a pairing request stores trust locally. It never disables unknown-device rejection." Style="{StaticResource MutedTextBlockStyle}" />
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>
