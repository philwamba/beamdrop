<Page
    x:Class="BeamDrop.Windows.App.Views.PrivacyPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer>
        <StackPanel Spacing="20" Padding="36">
            <TextBlock Text="Privacy" Style="{StaticResource PageTitleTextBlockStyle}" />
            <Border Style="{StaticResource DeviceCardStyle}">
                <StackPanel Spacing="12">
                    <TextBlock Text="Local-First Transfer" Style="{StaticResource SectionTitleTextBlockStyle}" />
                    <TextBlock Text="BeamDrop does not require login or cloud upload for local MVP transfers. Content should move over the local network whenever possible." Style="{StaticResource MutedTextBlockStyle}" />
                </StackPanel>
            </Border>
            <Border Style="{StaticResource DeviceCardStyle}">
                <StackPanel Spacing="12">
                    <TextBlock Text="Device Trust" Style="{StaticResource SectionTitleTextBlockStyle}" />
                    <TextBlock Text="Unknown devices require approval. Revoked devices are blocked before envelopes or content are accepted." Style="{StaticResource MutedTextBlockStyle}" />
                </StackPanel>
            </Border>
            <Border Style="{StaticResource DeviceCardStyle}">
                <StackPanel Spacing="12">
                    <TextBlock Text="Clipboard" Style="{StaticResource SectionTitleTextBlockStyle}" />
                    <TextBlock Text="Clipboard sharing is user-controlled. Sensitive-looking text must not be sent automatically." Style="{StaticResource MutedTextBlockStyle}" />
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>
