<Page
    x:Class="BeamDrop.Windows.App.Views.ClipboardPolicyPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <StackPanel Spacing="20" Padding="36">
        <TextBlock Text="Clipboard Policy" Style="{StaticResource PageTitleTextBlockStyle}" />
        <InfoBar Title="Clipboard Sharing Is Manual By Default" Message="BeamDrop does not silently send clipboard contents. Sensitive-looking text is blocked from automatic clipboard-send flows." Severity="Informational" IsOpen="True" />
        <Border Style="{StaticResource DeviceCardStyle}">
            <StackPanel Spacing="12">
                <RadioButton Content="Off" />
                <RadioButton Content="Manual Send Only" IsChecked="True" />
                <RadioButton Content="Watch While BeamDrop Is Open" IsEnabled="False" />
                <ToggleSwitch Header="Pause Clipboard Sharing" IsOn="False" />
                <TextBlock Text="Windows clipboard sharing must be visible, user-controlled, and limited to trusted targets." Style="{StaticResource MutedTextBlockStyle}" />
            </StackPanel>
        </Border>
    </StackPanel>
</Page>
