<Page
    x:Class="BeamDrop.Windows.App.Views.ClipboardPolicyPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <StackPanel Spacing="20" Padding="36">
        <TextBlock Text="Clipboard policy" Style="{StaticResource PageTitleTextBlockStyle}" />
        <InfoBar Title="Clipboard sharing is manual by default" Message="BeamDrop does not silently send clipboard contents. Watched clipboard modes require opt-in, visible status, and trusted targets." Severity="Informational" IsOpen="True" />
        <Border Style="{StaticResource DeviceCardStyle}">
            <StackPanel Spacing="12">
                <RadioButton Content="Off" />
                <RadioButton Content="Manual send only" IsChecked="True" />
                <RadioButton Content="Watch while BeamDrop is open" />
                <ToggleSwitch Header="Pause clipboard sharing" IsOn="False" />
            </StackPanel>
        </Border>
    </StackPanel>
</Page>
