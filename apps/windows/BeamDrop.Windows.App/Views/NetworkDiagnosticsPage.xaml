<Page
    x:Class="BeamDrop.Windows.App.Views.NetworkDiagnosticsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <StackPanel Spacing="20" Padding="36">
        <TextBlock Text="Network Diagnostics" Style="{StaticResource PageTitleTextBlockStyle}" />
        <Border Style="{StaticResource DeviceCardStyle}">
            <StackPanel Spacing="12">
                <TextBlock Text="Local Discovery" Style="{StaticResource SectionTitleTextBlockStyle}" />
                <TextBlock Text="Checks should cover firewall profile, network isolation, mDNS availability, listener port, and _beamdrop._tcp visibility." Style="{StaticResource MutedTextBlockStyle}" />
                <Button Content="Run Checks" HorizontalAlignment="Left" />
            </StackPanel>
        </Border>
        <InfoBar Title="Manual Fallback" Message="If discovery is blocked, pair with QR or manual endpoint. Authentication rules stay the same." Severity="Informational" IsOpen="True" />
    </StackPanel>
</Page>
