<Page
    x:Class="BeamDrop.Windows.App.Views.TrustedDevicesPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer>
        <StackPanel Spacing="20" Padding="36">
            <TextBlock Text="Trusted devices" Style="{StaticResource PageTitleTextBlockStyle}" />
            <Border Style="{StaticResource DeviceCardStyle}">
                <StackPanel Spacing="10">
                    <TextBlock Text="No trusted devices" Style="{StaticResource SectionTitleTextBlockStyle}" />
                    <TextBlock Text="Trusted peers are stored locally in SQLite. Revoked devices cannot transfer or resume until re-paired." Style="{StaticResource MutedTextBlockStyle}" />
                    <Button Content="Pair new device" HorizontalAlignment="Left" />
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>
