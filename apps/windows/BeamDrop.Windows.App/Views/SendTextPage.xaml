<Page
    x:Class="BeamDrop.Windows.App.Views.SendTextPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Padding="36" RowSpacing="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <TextBlock Text="Send text" Style="{StaticResource PageTitleTextBlockStyle}" />
        <TextBox Grid.Row="1" Header="Text" PlaceholderText="Type or paste text to send" AcceptsReturn="True" TextWrapping="Wrap" />
        <CommandBar Grid.Row="2" DefaultLabelPosition="Right">
            <AppBarButton Icon="Paste" Label="Paste" />
            <AppBarButton Icon="Send" Label="Send to trusted device" />
        </CommandBar>
    </Grid>
</Page>
