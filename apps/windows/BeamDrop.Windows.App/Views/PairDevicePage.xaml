<Page
    x:Class="BeamDrop.Windows.App.Views.PairDevicePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer>
        <StackPanel Spacing="20" Padding="36">
            <TextBlock Text="Pair device" Style="{StaticResource PageTitleTextBlockStyle}" />
            <Grid ColumnSpacing="18">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="360" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Border Style="{StaticResource DeviceCardStyle}" Height="360">
                    <Grid Background="{ThemeResource LayerFillColorDefaultBrush}">
                        <TextBlock Text="QR" FontSize="64" FontWeight="SemiBold" HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Grid>
                </Border>
                <StackPanel Grid.Column="1" Spacing="14">
                    <TextBlock Text="Show this QR on the receiving device" Style="{StaticResource SectionTitleTextBlockStyle}" />
                    <TextBlock Text="Payload includes device ID, public key, protocol version, service name, and endpoint hints. It contains no reusable secret." Style="{StaticResource MutedTextBlockStyle}" />
                    <TextBox Header="Manual pairing code" Text="beamdrop://pairing/session-preview" IsReadOnly="True" />
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <Button Content="Refresh QR" />
                        <Button Content="Scan another QR" />
                    </StackPanel>
                </StackPanel>
            </Grid>
        </StackPanel>
    </ScrollViewer>
</Page>
